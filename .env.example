# ============================================================
# Configuration SQL Server 2012 - Système d'Archivage
# ============================================================

# Environnement (development | production | test)
NODE_ENV=development

# Configuration SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_NAME=archivage
DB_USER=sa
DB_PASSWORD=your_password_here

# Pool de connexions
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_IDLE_TIMEOUT=30000
DB_CONN_TIMEOUT=5000

# JWT Secret (à changer en production)
JWT_SECRET=secret_key_change_in_production

# Port du serveur backend
PORT=3000
